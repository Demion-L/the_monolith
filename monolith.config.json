{
  "project": {
    "name": "WEBWAY",
    "language": "typescript",
    "packageManager": "pnpm",
    "aiTool": "claude"
  },
  "monolithRoot": ".monolith",
  "finalizationProtocol": "finalize-story",
  "gates": {
    "enabled": [
      "emission",
      "memory-update",
      "mistake-injection",
      "governance-boundary",
      "protocol-drift"
    ]
  },
  "models": {
    "default": "claude-opus",
    "local": null,
    "tiers": {
      "implementation": "default",
      "review": "default",
      "planning": "default",
      "sensitive": "local"
    }
  }
}
